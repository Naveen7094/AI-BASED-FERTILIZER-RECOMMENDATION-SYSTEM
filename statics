body {
    font-family: Arial, sans-serif;
    background-color: #e8f5e9;
}

.container {
    width: 400px;
    margin: 100px auto;
    background: white;
    padding: 25px;
    text-align: center;
    border-radius: 10px;
}

input, button {
    width: 90%;
    padding: 10px;
    margin: 8px;
}

button {
    background-color: green;
    color: white;
    border: none;
    cursor: pointer;
}

h3 {
    color: green;
}
